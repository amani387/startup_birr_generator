# Disable email confirmation: Supabase Dashboard → Authentication → Providers → Email → turn OFF "Confirm email"

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Server-only — never expose in client bundles
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — MUST match your live domain (no trailing slash)
# Production:
NEXT_PUBLIC_APP_URL=https://gogenzeb.com
# Legacy IP (only if domain not configured yet):
# NEXT_PUBLIC_APP_URL=http://213.254.179.94
# Local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional
CRON_SECRET=your-cron-secret

# Social task links (Reward Tasks on dashboard)
NEXT_PUBLIC_FACEBOOK_PAGE_URL=
NEXT_PUBLIC_FACEBOOK_SHARE_URL=
NEXT_PUBLIC_FACEBOOK_COMMENT_URL=
NEXT_PUBLIC_TELEGRAM_GROUP_URL=
NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=
NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=
NEXT_PUBLIC_YOUTUBE_LIKE_URL=
NEXT_PUBLIC_YOUTUBE_COMMENT_URL=
NEXT_PUBLIC_YOUTUBE_WATCH_URL=
