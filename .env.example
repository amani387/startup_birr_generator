# Disable email confirmation: Supabase Dashboard → Authentication → Providers → Email → turn OFF "Confirm email"

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Server-only — never expose in client bundles
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — MUST match your deployed domain/IP (no trailing slash)
# Production VPS:
NEXT_PUBLIC_APP_URL=http://213.254.179.94
# Local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional
CRON_SECRET=your-cron-secret
